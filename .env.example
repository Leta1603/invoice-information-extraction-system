# ──────────────────────────────────────────────────────
#  Copy this file to .env and fill in your real values.
# ──────────────────────────────────────────────────────

# ── FastAPI backend ────────────────────────────────────
APP_NAME=Invoice Diploma API
DEBUG=false

# ── ML model ──────────────────────────────────────────
# Path inside the container: /app/app/models/best_fcos_detector.pt
# (resolved automatically via config.py — override only if needed)
# MODEL_PATH=/app/app/models/best_fcos_detector.pt
DEVICE=cpu

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=invoicedb
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/invoicedb

# ── MinIO / S3 ─────────────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=invoices

# ── Google Sheets ──────────────────────────────────────
# Place your service-account JSON at backend/app/credentials.json
# and set the spreadsheet name below.
GOOGLE_SHEETS_CREDENTIALS=/app/app/credentials.json
GOOGLE_SHEET_NAME=Invoice Data

# ── Telegram bot ───────────────────────────────────────
BOT_TOKEN=your_bot_token_here
API_BASE_URL=http://backend:8000
